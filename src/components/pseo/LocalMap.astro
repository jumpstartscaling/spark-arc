---
interface Props {
  city: string;
  state: string;
  neighborhood: string;
}

const { city, state, neighborhood } = Astro.props;

// We use a generic search URL that Google Maps safely handles without an API key for embeds
const mapUrl = `https://www.google.com/maps/embed/v1/place?key=REPLACE_WITH_GOOGLE_MAPS_API_KEY&q=${encodeURIComponent(`${neighborhood}, ${city}, ${state}`)}`;
// Fallback for demo/dev: use a searchable public URL if no key
const publicMapUrl = `https://www.google.com/maps?q=${encodeURIComponent(`${neighborhood}, ${city}, ${state}`)}&output=embed`;
---

<section class="my-24 px-4">
  <div class="mx-auto max-w-4xl overflow-hidden rounded-[2.5rem] border-4 border-white bg-slate-200 shadow-2xl">
    <div class="flex flex-col md:flex-row">
      <div class="bg-slate-900 p-8 md:w-1/3 text-white flex flex-col justify-center">
        <p class="text-xs font-bold uppercase tracking-widest text-blue-400 mb-2">Service Area Hub</p>
        <h2 class="text-2xl font-black leading-tight">{city} Operations</h2>
        <p class="mt-4 text-sm text-slate-400 leading-relaxed">
          Current coverage active for **{neighborhood}** and surrounding {state} corridors. Our locally-verified network is currently dispatched within 10 miles of this zone.
        </p>
        <div class="mt-8 flex items-center gap-3 text-xs font-bold text-blue-400">
          <span class="h-2 w-2 animate-ping rounded-full bg-blue-400"></span>
          Real-time Dispatch Active
        </div>
      </div>
      <div class="h-[350px] flex-1 relative bg-slate-100">
        <iframe
          width="100%"
          height="100%"
          style="border:0"
          loading="lazy"
          allowfullscreen
          src={publicMapUrl}
        ></iframe>
      </div>
    </div>
  </div>
</section>
