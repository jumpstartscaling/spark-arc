---
const layers = [
  { name: 'Ridge ventilation', color: '#1e293b', note: 'Continuous airflow path' },
  { name: 'Laminate shingle', color: '#334155', note: 'Impact class varies by line' },
  { name: 'Leak barrier', color: '#2563eb', note: 'Ice / water shield at valleys' },
  { name: 'Synthetic underlayment', color: '#64748b', note: 'Grip + secondary barrier' },
  { name: 'Roof deck', color: '#94a3b8', note: 'Structural substrate' },
];
---

<section class="my-20 px-4">
  <div class="mx-auto flex max-w-4xl flex-col items-center gap-12 md:flex-row">
    <div class="w-full md:w-1/2">
      <svg viewBox="0 0 300 400" class="w-full drop-shadow-xl">
        {layers.map((layer, i) => (
          <g transform={`translate(0, ${i * 65})`}>
            <rect x="20" y="20" width="260" height="40" rx="4" fill={layer.color} class="transition-opacity hover:opacity-90" />
            <text x="40" y="45" fill="white" font-size="12" font-weight="bold" class="uppercase tracking-widest">
              {layer.name}
            </text>
            <line x1="280" y1="40" x2="300" y2="40" stroke="#e2e8f0" stroke-width="1" />
          </g>
        ))}
      </svg>
    </div>

    <div class="w-full md:w-1/2">
      <h2 class="mb-6 text-3xl font-black uppercase leading-tight tracking-tighter text-slate-900">
        The anatomy of a <span class="italic text-blue-600">certified</span> system
      </h2>
      <ul class="space-y-4">
        {layers.map((layer) => (
          <li class="flex items-start gap-4">
            <div class="mt-2 h-2 w-2 rounded-full" style={`background-color: ${layer.color}`} />
            <div>
              <p class="mb-1 font-bold leading-none text-slate-800">{layer.name}</p>
              <p class="text-sm text-slate-500">{layer.note}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
