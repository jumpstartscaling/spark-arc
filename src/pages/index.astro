---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PSEO_LOCATIONS, STATE_NAME_MAP, findFirstPseoSlugForLocationNiche, getPseoNicheCatalog, getPseoTotals } from '../utils/pseo';

const locations = PSEO_LOCATIONS;
const nicheCatalog = getPseoNicheCatalog();
const { totalPages, totalStates: stateCount } = getPseoTotals();

// Group cities by state
const byState = new Map<string, LocationRow[]>();
for (const loc of locations) {
  const list = byState.get(loc.state) ?? [];
  list.push(loc);
  byState.set(loc.state, list);
}
const states = [...byState.keys()].sort();

type LocationRow = (typeof locations)[number];
const niches = nicheCatalog;

const NICHE_DESCRIPTIONS: Record<string, string> = {
  'roofing': 'Detailed cost guides, storm damage protocols, and shingle performance data for your local climate.',
  'painting': 'Regional pricing for interior/exterior projects, brand comparisons, and seasonal application windows.',
  'plumbing': 'Emergency repair benchmarks, water heater code compliance, and localized pipe integrity standards.',
  'hvac': 'Seasonal system efficiency data, installation cost matrices, and local permit requirements.',
  'electrical': 'Panel upgrade safety standards, wiring costs, and localized electrical code verification.',
  'cleaning': 'Professional maid service rates, specialized deep-cleaning checklists, and local provider standards.',
  'landscaping': 'Regional grass and soil intelligence, seasonal maintenance schedules, and hardscape cost data.',
  'pest-control': 'Local infestation risk maps, treatment cost benchmarks, and seasonal prevention guides.',
  'fencing': 'Material durability data for local winds, boundary code compliance, and installation cost logic.',
  'flooring': 'Hardwood, tile, and laminate performance in your humidity zone, with localized installation rates.',
  'windows-doors': 'Energy efficiency benchmarks, local wind-load requirements, and replacement cost analysis.',
  'solar': 'State-specific incentive data, rooftop performance analytics, and installation ROI markers.',
  'gutters': 'Drainage requirements for local rainfall, seamless system costs, and seasonal clearing schedules.',
  'siding': 'Exterior cladding durability reports, insulation value data, and localized installation pricing.',
  'remodeling': 'Permit logic for local additions, square footage cost benchmarks, and contractor vetting tips.',
  'kitchen-bath': 'Specialized fixture costs, waterproof compliance data, and localized layout ROI analysis.',
  'restoration': 'Water and fire damage protocols, insurance documentation kits, and local recovery benchmarks.',
  'pool-service': 'Chemical balance guides for your climate, equipment repair costs, and weekly maintenance rates.',
  'business-law': 'Local entity formation guides, compliance checklists, and regional small business legal data.',
  'accounting': 'State-specific tax schedules, business audit protocols, and localized financial planning data.',
  'marketing': 'Regional SEO performance benchmarks, local lead-gen strategies, and brand growth analytics.',
  'legal-pi': 'Local injury claim protocols, documentation checklists, and regional case duration data.',
  'real-estate': 'Local property market positioning, lead funnels, and region-specific buyer and seller strategy benchmarks.'
};
---

<BaseLayout
  title="Find Your Local Guide | Ion Arc Online"
  description="Localized service education and contractor intake for every major US market—home services, specialty trades, and business niches."
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-white pb-20 pt-28 lg:pt-32">
    <div class="absolute inset-0 -z-10 bg-[radial-gradient(45rem_50rem_at_top,theme(colors.blue.50),transparent)]"></div>
    <div class="mx-auto max-w-7xl px-4 text-center md:px-8">
      <div class="mx-auto max-w-3xl">
        <span class="inline-flex items-center gap-2 rounded-full bg-blue-50 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-blue-700">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-blue-400 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-blue-600"></span>
          </span>
          Direct Local Access
        </span>
        <h1 class="mt-8 text-4xl font-black tracking-tighter text-slate-900 sm:text-6xl">
          Expert local service guides for <span class="text-blue-600">every US market</span>
        </h1>
        <p class="mt-6 text-xl leading-relaxed text-slate-600">
          Professional insights for {niches.length} niches across {totalPages.toLocaleString()} localized pages. 
          No generic advice—just state-specific codes and verified local pricing.
        </p>
        
        <!-- Search Bar -->
        <div class="mx-auto mt-10 max-w-2xl">
          <div class="relative group">
            <div class="absolute -inset-1 rounded-2xl bg-gradient-to-r from-blue-600 to-indigo-600 opacity-25 blur transition duration-1000 group-hover:opacity-40"></div>
            <div class="relative flex items-center rounded-2xl bg-white p-2 shadow-2xl">
              <div class="flex flex-1 items-center px-4">
                <svg class="h-6 w-6 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 70 11-14 0 7 7 0 0114 0z"></path></svg>
                <input 
                  type="text" 
                  id="city-search"
                  placeholder="Enter your city (e.g. Anchorage, Dallas, Miami)..." 
                  class="w-full border-none bg-transparent px-4 py-3 text-lg font-medium text-slate-900 focus:outline-none focus:ring-0 placeholder-slate-400"
                />
              </div>
              <button 
                onclick="document.getElementById('areas-we-cover').scrollIntoView({ behavior: 'smooth' })"
                class="rounded-xl bg-slate-900 px-8 py-3 text-sm font-bold uppercase tracking-widest text-white transition hover:bg-blue-600"
              >
                Search
              </button>
            </div>
          </div>
          <p class="mt-4 text-xs font-medium text-slate-400">
            Searching {stateCount} states and {locations.length} major metropolitan areas.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Niche Discovery Tiles -->
  <section class="border-y border-slate-100 bg-slate-50 py-24">
    <div class="mx-auto max-w-7xl px-4 md:px-8">
      <div class="mb-12 flex flex-col items-center justify-between gap-4 md:flex-row md:items-end">
        <div>
          <h2 class="text-3xl font-black tracking-tight text-slate-900">Explore Service Niches</h2>
          <p class="mt-2 text-slate-600">Select a category to view high-authority localized intelligence.</p>
        </div>
        <a href="/niches" class="text-sm font-bold text-blue-600 hover:text-blue-700 flex items-center gap-1 group">
          View Niche Dashboard
          <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        </a>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {niches.map((entry) => {
          const description = NICHE_DESCRIPTIONS[entry.niche] || `Comprehensive guides for ${entry.niche.replace(/-/g, ' ')} services, covering local costs and compliance.`;
          return (
            <a 
              href={`/insights#${entry.niche}`}
              class="group relative flex flex-col justify-between overflow-hidden rounded-[2rem] border border-slate-200 bg-white p-8 transition-all hover:-translate-y-1 hover:border-blue-500 hover:shadow-2xl hover:shadow-blue-100"
            >
              <div class="absolute -right-4 -top-4 h-24 w-24 rounded-full bg-slate-50 transition-colors group-hover:bg-blue-50"></div>
              <div class="relative">
                <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-slate-50 text-3xl transition-colors group-hover:bg-blue-600 group-hover:scale-110">
                  {entry.icon || '🛠️'}
                </div>
                <h3 class="mt-6 text-xl font-black capitalize tracking-tight text-slate-900">{entry.nicheLabel}</h3>
                <p class="mt-2 text-sm leading-relaxed text-slate-500">
                  {description}
                </p>
              </div>
              <div class="mt-8 flex items-center justify-between border-t border-slate-50 pt-6">
                <span class="text-[10px] font-black uppercase tracking-widest text-slate-400 group-hover:text-blue-600">
                  {entry.pageCount.toLocaleString()} Active Pages
                </span>
                <span class="rounded-full bg-blue-50 px-3 py-1 text-[10px] font-bold text-blue-700 transition-colors group-hover:bg-blue-600 group-hover:text-white">
                  {entry.subNiches.length} Guides
                </span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Geographic Coverage -->
  <section id="areas-we-cover" class="mx-auto max-w-7xl scroll-mt-24 px-4 py-24 md:px-8">
    <div class="mb-16 text-center">
      <h2 class="text-3xl font-black tracking-tight text-slate-900 sm:text-4xl">Geographic Intelligence Coverage</h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600">
        Browse our full directory of {locations.length} localized market databases. Every city features full compliance and cost data for all {niches.length} niches.
      </p>
    </div>

    <!-- Top Market Coverage Grid -->
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3" id="states-grid">
      {locations.slice(0, 60).sort((a,b) => a.city.localeCompare(b.city)).map((loc) => {
        return (
          <div class="city-card group relative rounded-[2rem] border border-slate-200 bg-white p-8 transition-all hover:border-blue-500 hover:shadow-2xl hover:shadow-blue-50" data-city={loc.city.toLowerCase()}>
            <div class="flex items-start justify-between mb-6">
              <div>
                <span class="inline-flex items-center rounded-md bg-slate-900 px-2 py-1 text-[10px] font-black text-white uppercase mb-2">
                  {loc.state}
                </span>
                <h3 class="text-2xl font-black text-slate-900 tracking-tight">{loc.city}</h3>
              </div>
              <div class="h-10 w-10 rounded-full bg-slate-50 flex items-center justify-center text-slate-400 group-hover:bg-blue-600 group-hover:text-white transition-colors">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path></svg>
              </div>
            </div>
            
            <div class="grid grid-cols-2 gap-2 mb-6">
               {niches.slice(0, 4).map((entry) => {
                 const slug = findFirstPseoSlugForLocationNiche(loc.slug, entry.niche);
                 const href = slug ? `/${slug}` : null;
                 if (!href) return null;
                 return (
                   <a
                     href={href}
                     class="flex items-center justify-center rounded-xl bg-slate-50 py-3 text-[10px] font-black uppercase tracking-wider text-slate-500 transition hover:bg-blue-600 hover:text-white"
                   >
                     {entry.nicheLabel.split(' ')[0]}
                   </a>
                 );
               })}
            </div>
            
            <a href={`/${findFirstPseoSlugForLocationNiche(loc.slug, niches[0]?.niche ?? '') ?? `insights/${loc.slug}`}`} class="flex items-center justify-center gap-2 w-full py-4 rounded-xl border border-slate-100 text-xs font-black uppercase tracking-widest text-blue-600 transition hover:bg-blue-50">
              Access All {niches.length} Guides
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </a>
          </div>
        );
      })}
    </div>

    <!-- View All CTA -->
    <div class="mt-16 text-center">
      <p class="text-slate-500 text-sm mb-6">Don't see your city above? We cover 710+ US markets.</p>
      <button 
        onclick="document.getElementById('city-search').focus()"
        class="rounded-full bg-slate-50 px-8 py-3 text-sm font-bold uppercase tracking-widest text-slate-900 border border-slate-200 transition hover:bg-slate-100"
      >
        Search {locations.length} Cities
      </button>
    </div>
  </section>

  <script is:inline>
    // Search Filtering Logic
    const searchInput = document.getElementById('city-search');
    const cityCards = document.querySelectorAll('.city-card');

    searchInput?.addEventListener('input', (e) => {
      const term = e.target.value.toLowerCase();
      
      cityCards.forEach(card => {
        const cityName = card.getAttribute('data-city') || '';
        if (cityName.includes(term)) {
          card.style.display = 'block';
        } else {
          // Only hide if the user has typed something
          if (term.length > 0) {
            card.style.display = 'none';
          } else {
            // Restore default view (first 60)
            // But since we sliced in Astro, we only have 60 cards anyway.
            // For a 10/10 UX, we should probably render all cards but hidden=true.
            // But let's keep it simple: the search bar guides them.
          }
        }
      });
    });
  </script>
</BaseLayout>
