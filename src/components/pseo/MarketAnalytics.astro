---
import type { MarketAnalyticsData } from '../../types/pseo';

interface Props {
  data: MarketAnalyticsData;
}

const { data } = Astro.props;
---

<section class="my-24 px-4">
  <div class="mx-auto max-w-5xl">
    <div class="rounded-[3rem] bg-slate-900 p-8 md:p-16 text-white shadow-2xl relative overflow-hidden">
      <!-- Decorative element -->
      <div class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-blue-500/10 blur-3xl"></div>
      
      <div class="relative z-10 flex flex-col md:flex-row gap-12 items-center">
        <div class="flex-1">
          <p class="text-sm font-bold uppercase tracking-[0.2em] text-blue-400 mb-4">Local Market Data</p>
          <h2 class="text-3xl md:text-4xl font-black tracking-tight leading-tight">
            {data.headline}
          </h2>
          <p class="mt-6 text-lg text-slate-300 leading-relaxed italic">
            "{data.analysis}"
          </p>
        </div>

        <div class="w-full md:w-auto grid grid-cols-1 sm:grid-cols-2 gap-4">
          {data.stats.map(stat => (
            <div class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm transition hover:bg-white/10">
              <p class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">{stat.label}</p>
              <p class="text-3xl font-black text-blue-400">{stat.value}</p>
              <p class="mt-2 text-[10px] leading-tight text-slate-500 font-medium">{stat.hint}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
