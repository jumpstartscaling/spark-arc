import BaseLayout from '../layouts/BaseLayout.astro';
import { pseoContent, STATE_NAME_MAP } from '../utils/pseo';
import locationsData from '../data/pseo/locations.json';

interface LocationRow {
  city: string;
  state: string;
  slug: string;
  county: string;
}

const locations = locationsData as unknown as LocationRow[];

// Group by state, then by city
const byState = new Map<string, LocationRow[]>();
for (const loc of locations) {
  const list = byState.get(loc.state) ?? [];
  list.push(loc);
  byState.set(loc.state, list);
}

const states = [...byState.keys()].sort((a, b) => a.localeCompare(b));

const count = pseoContent.length;
const stateCount = states.length;
---

<BaseLayout
  title="Spark Arc | Tampa Bay & Gulf Coast roofing guides"
  description="Local roofing education and intake for Hillsborough, Pinellas, Pasco, Polk, Hernando, Sarasota, Manatee, and Collier counties."
>
  <section class="border-b border-slate-200 bg-white px-4 py-16 text-center md:py-20">
    <p class="text-sm font-bold uppercase tracking-widest text-blue-600">West Central Florida</p>
    <h1 class="mx-auto mt-4 max-w-3xl text-4xl font-black tracking-tight text-slate-900 md:text-5xl">
      Roofing guides built for real cities—not placeholders
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-600">
      Every page is generated from structured location data (county, landmarks, parks) so copy stays grounded.
      Use the checklist survey to route leads with UTMs and webhook-ready payloads.
    </p>
    <p class="mt-4 text-sm text-slate-500">
      {count} live guide pages across {stateCount} states in this build.
    </p>
    <div class="mt-10 flex flex-wrap justify-center gap-4">
      <a
        href="#areas-we-cover"
        class="inline-flex items-center justify-center rounded-xl bg-blue-600 px-8 py-4 text-sm font-bold uppercase tracking-wider text-white shadow-lg shadow-blue-200 transition hover:bg-blue-700"
      >
        Explore Markets
      </a>
      <a
        href="/insights"
        class="inline-flex items-center justify-center rounded-xl border-2 border-slate-200 bg-white px-8 py-4 text-sm font-bold uppercase tracking-wider text-slate-800 transition hover:border-blue-300 hover:text-blue-700"
      >
        All guides
      </a>
    </div>
  </section>

  <section id="areas-we-cover" class="mx-auto max-w-6xl scroll-mt-24 px-4 py-16">
    <h2 class="text-center text-2xl font-black text-slate-900 md:text-3xl">Geographic Coverage</h2>
    <p class="mx-auto mt-3 max-w-2xl text-center text-slate-600">
      Select a state and city to view localized roofing insights and intake resources.
    </p>

    <div class="mt-12 space-y-16">
      {
        states.map((stateCode) => {
          const stateCities = (byState.get(stateCode) || []).sort((a, b) => a.city.localeCompare(b.city));
          return (
            <div>
              <h3 class="flex items-center gap-3 border-b border-slate-200 pb-3 text-xl font-bold text-slate-900">
                <span class="rounded-md bg-blue-600 px-2 py-1 text-xs text-white uppercase">{stateCode}</span>
                {STATE_NAME_MAP[stateCode] || stateCode}
              </h3>
              <ul class="mt-6 grid gap-3 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
                {stateCities.map((loc) => (
                  <li>
                    <a
                      href={`/insights/${loc.slug}/roofing`}
                      class="group block rounded-xl border border-slate-200 bg-white px-4 py-4 text-sm font-bold text-slate-800 shadow-sm transition hover:border-blue-500 hover:bg-blue-50/50 hover:text-blue-700"
                    >
                      <span class="block text-slate-900 group-hover:text-blue-700">{loc.city}</span>
                      <span class="mt-1 block text-xs font-normal text-slate-500 italic">{loc.county || ''}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          );
        })
      }
    </div>
  </section>
</BaseLayout>
