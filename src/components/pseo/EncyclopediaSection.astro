---
import type { EncyclopediaData } from '../../types/pseo';

interface Props {
  data: EncyclopediaData;
  niche: string;
}

const { data, niche } = Astro.props;

const brandKeys = Object.keys(data.brands);
const styleKeys = Object.keys(data.styles);
const costKeys = Object.keys(data.costs);
---

<section class="my-20 px-4">
  <div class="mx-auto max-w-4xl">
    <div class="prose prose-slate max-w-none">
      <p class="text-lg leading-relaxed text-slate-600">{data.aoe_intro}</p>
    </div>

    <h2 class="mt-16 text-3xl font-black uppercase tracking-tighter text-slate-900">
      Major {niche} Brands
    </h2>
    <div class="mt-8 grid gap-6 md:grid-cols-2">
      {
        brandKeys.map((key) => {
          const b = data.brands[key]!;
          return (
            <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:shadow-md">
              <p class="text-xs font-bold uppercase tracking-widest text-blue-600">{key.replace(/_/g, ' ')}</p>
              <p class="mt-2 text-sm text-slate-500">{b.tier} · Flagship: {b.flagship}</p>
              <p class="mt-3 text-slate-800 leading-relaxed font-medium">{b.value_prop}</p>
              <div class="mt-4 flex items-center justify-between border-t border-slate-50 pt-4">
                <span class="text-xs font-bold uppercase text-slate-400">Typical Tier</span>
                <span class="text-sm font-black text-slate-900">{b.price_point}</span>
              </div>
            </div>
          );
        })
      }
    </div>

    <h2 class="mt-20 text-3xl font-black uppercase tracking-tighter text-slate-900">
      Service Varieties
    </h2>
    <div class="mt-8 grid gap-4">
      {
        styleKeys.map((key) => {
          const s = data.styles[key]!;
          return (
            <div class="rounded-2xl border border-slate-100 bg-slate-50/80 px-8 py-6">
              <p class="text-xl font-bold text-slate-900">
                {key}: {s.human_name}
              </p>
              <p class="mt-2 text-slate-600 leading-relaxed">{s.benefit}</p>
              <p class="mt-3 text-sm font-medium text-slate-500 italic">Expert Note: {s.aoe_hint}</p>
            </div>
          );
        })
      }
    </div>

    <h2 class="mt-20 text-3xl font-black uppercase tracking-tighter text-slate-900">
      2026 Price Benchmarks
    </h2>
    <div class="mt-8 overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-lg">
      <table class="w-full text-left text-sm">
        <thead class="bg-slate-900 text-white">
          <tr>
            <th class="px-6 py-4 font-bold uppercase tracking-wider">System Category</th>
            <th class="px-6 py-4 font-bold uppercase tracking-wider">Estimated Logic</th>
            <th class="px-6 py-4 font-bold uppercase tracking-wider">Market Notes</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {
            costKeys.map((key) => {
              const c = data.costs[key]!;
              return (
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-5 font-bold text-slate-800">{key.replace(/_/g, ' ')}</td>
                  <td class="px-6 py-5 font-black text-blue-700">{c.per_sqft}</td>
                  <td class="px-6 py-5 text-slate-600 leading-relaxed">{c.notes}</td>
                </tr>
              );
            })
          }
        </tbody>
      </table>
    </div>
  </div>
</section>
