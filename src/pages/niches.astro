---
import BaseLayout from '../layouts/BaseLayout.astro';
import { pseoContent } from '../utils/pseo';

// Aggregate stats from generated content
const statsMap: Record<string, {
  category: string;
  niche: string;
  subNiches: Set<string>;
  cities: Set<string>;
  pageCount: number;
}> = {};

for (const entry of pseoContent) {
  const key = entry.niche;
  if (!statsMap[key]) {
    statsMap[key] = {
      category: entry.category,
      niche: entry.niche,
      subNiches: new Set(),
      cities: new Set(),
      pageCount: 0,
    };
  }
  statsMap[key]!.subNiches.add(entry.subNiche);
  statsMap[key]!.cities.add(entry.city);
  statsMap[key]!.pageCount++;
}

const niches = Object.values(statsMap).sort((a, b) =>
  a.category.localeCompare(b.category) || a.niche.localeCompare(b.niche)
);

const totalPages = pseoContent.length;
const totalCities = new Set(pseoContent.map(e => e.city)).size;

// Category colors
const categoryColors: Record<string, string> = {
  'home-services':      'bg-blue-100 text-blue-800 border-blue-200',
  'specialized-trades': 'bg-purple-100 text-purple-800 border-purple-200',
  'professional-services': 'bg-emerald-100 text-emerald-800 border-emerald-200',
};

const categoryLabels: Record<string, string> = {
  'home-services': 'Home Services',
  'specialized-trades': 'Specialized Trades',
  'professional-services': 'Professional & B2B',
};

// File path template for how to add a new niche
const exampleJson = `{
  "service_config": {
    "niche": "Electrical",
    "niche_slug": "electrical",
    "category": "Home Services",
    "category_slug": "home-services",
    "icon": "⚡",
    "sub_niches": [
      { "label": "Panel Upgrades",      "slug": "panel-upgrades"      },
      { "label": "EV Charger Install",  "slug": "ev-charger-install"  },
      { "label": "Lighting Design",     "slug": "lighting-design"     },
      { "label": "Rewiring",            "slug": "rewiring"            },
      { "label": "Surge Protection",    "slug": "surge-protection"    }
    ]
  },
  "spintax": { "synonyms": [] },
  "show_tell": { ... },
  "trust": { ... },
  "encyclopedia": { ... },
  "sub_niche_templates": {
    "panel-upgrades": {
      "headline_templates": [...],
      "faqs": [...],
      "lead_magnet": { ... },
      "survey": { ... }
    }
  },
  "regional_nuance": {
    "TX": { "focus": "...", "top_brand": "...", "tech": "...", "logic": "..." },
    "FL": { ... },
    "NC": { ... },
    "CO": { ... }
  },
  "conversion": { "closing_trust": "..." }
}`;
---

<BaseLayout title="Niche Dashboard — Spark Arc" description="Admin view of all registered pSEO niches, sub-niches, and page counts.">
  <div class="min-h-screen bg-slate-900 text-white">

    <!-- Header -->
    <div class="border-b border-slate-700 bg-slate-800 px-6 py-8">
      <div class="mx-auto max-w-6xl">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-slate-400">Spark Arc</p>
            <h1 class="mt-1 text-3xl font-black text-white">Niche Dashboard</h1>
            <p class="mt-2 text-slate-400">All registered campaign niches, sub-niches, and live page counts.</p>
          </div>
          <div class="flex gap-4">
            <div class="rounded-2xl border border-slate-600 bg-slate-700 px-6 py-4 text-center">
              <p class="text-3xl font-black text-white">{totalPages.toLocaleString()}</p>
              <p class="mt-1 text-xs font-semibold uppercase tracking-wider text-slate-400">Total Pages</p>
            </div>
            <div class="rounded-2xl border border-slate-600 bg-slate-700 px-6 py-4 text-center">
              <p class="text-3xl font-black text-white">{totalCities}</p>
              <p class="mt-1 text-xs font-semibold uppercase tracking-wider text-slate-400">Cities</p>
            </div>
            <div class="rounded-2xl border border-slate-600 bg-slate-700 px-6 py-4 text-center">
              <p class="text-3xl font-black text-white">{niches.length}</p>
              <p class="mt-1 text-xs font-semibold uppercase tracking-wider text-slate-400">Active Niches</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="mx-auto max-w-6xl px-6 py-12 space-y-16">

      <!-- Niche Cards -->
      <section>
        <h2 class="mb-6 text-xl font-bold text-white">Active Campaigns</h2>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {niches.map((n) => (
            <div class="rounded-2xl border border-slate-700 bg-slate-800 p-6">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <span class={`inline-block rounded-full border px-3 py-0.5 text-xs font-bold uppercase tracking-wider ${categoryColors[n.category] ?? 'bg-slate-700 text-slate-300 border-slate-600'}`}>
                    {categoryLabels[n.category] ?? n.category}
                  </span>
                  <h3 class="mt-3 text-xl font-black capitalize text-white">{n.niche}</h3>
                </div>
                <div class="text-right">
                  <p class="text-2xl font-black text-blue-400">{n.pageCount.toLocaleString()}</p>
                  <p class="text-xs text-slate-500">pages</p>
                </div>
              </div>

              <div class="mt-4 space-y-1">
                {[...n.subNiches].sort().map((sn) => (
                  <div class="flex items-center gap-2">
                    <span class="h-1.5 w-1.5 rounded-full bg-blue-500 flex-shrink-0"></span>
                    <span class="text-sm text-slate-300 capitalize">{sn.replace(/-/g, ' ')}</span>
                  </div>
                ))}
              </div>

              <div class="mt-5 border-t border-slate-700 pt-4 flex items-center justify-between text-xs text-slate-500">
                <span>{n.cities.size} cities</span>
                <span>{n.subNiches.size} sub-niches</span>
                <a
                  href={`/insights/${[...pseoContent].find(e => e.niche === n.niche)?.slug.replace('insights/', '')?.split('/').slice(0, -1).join('/') ?? ''}`}
                  class="text-blue-400 hover:text-blue-300 font-semibold"
                >
                  View sample →
                </a>
              </div>
            </div>
          ))}

          <!-- Placeholder cards for unbuilt niches -->
          {[
            { label: 'Electrical',  cat: 'Home Services',     slug: 'electrical'  },
            { label: 'Pest Control',cat: 'Home Services',     slug: 'pest-control'},
            { label: 'Landscaping', cat: 'Home Services',     slug: 'landscaping' },
            { label: 'Cleaning',    cat: 'Home Services',     slug: 'cleaning'    },
            { label: 'Restoration', cat: 'Home Services',     slug: 'restoration' },
            { label: 'Flooring',    cat: 'Home Services',     slug: 'flooring'    },
            { label: 'Legal',       cat: 'Professional & B2B','slug': 'legal'     },
            { label: 'HVAC',        cat: 'Home Services',     slug: 'hvac'        },
          ].filter(p => !niches.find(n => n.niche === p.slug)).map((p) => (
            <div class="rounded-2xl border border-dashed border-slate-600 bg-slate-800/40 p-6 opacity-60">
              <span class="inline-block rounded-full border border-slate-600 bg-slate-700 px-3 py-0.5 text-xs font-bold uppercase tracking-wider text-slate-400">
                {p.cat}
              </span>
              <h3 class="mt-3 text-xl font-black text-slate-400">{p.label}</h3>
              <p class="mt-3 text-sm text-slate-500">Not yet added</p>
              <p class="mt-1 text-xs text-slate-600 font-mono">campaigns/home-services/{p.slug}.json</p>
              <div class="mt-4 border-t border-slate-700 pt-3">
                <span class="text-xs text-slate-600">0 pages · Awaiting JSON</span>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- How to Add a Niche -->
      <section>
        <h2 class="mb-2 text-xl font-bold text-white">How to Add a New Niche</h2>
        <p class="mb-6 text-slate-400">Each niche is a single self-contained JSON file. Supply one file and the engine auto-generates <strong class="text-white">cities × sub-niches</strong> pages.</p>

        <div class="grid gap-6 md:grid-cols-2">
          <!-- Steps -->
          <div class="space-y-4">
            {[
              { step: '1', title: 'Create the JSON file', body: 'Copy the schema below and save as:\nsrc/data/pseo/campaigns/[category]/[niche].json' },
              { step: '2', title: 'Fill in the 4 sections', body: 'service_config · spintax · sub_niche_templates · regional_nuance' },
              { step: '3', title: 'Register in the generator', body: 'Add one import line + one array entry in:\nsrc/utils/generatePseoPages.ts' },
              { step: '4', title: 'Build & verify', body: 'Run npm run build — page count will jump by cities × sub-niches.' },
            ].map(({ step, title, body }) => (
              <div class="flex gap-4 rounded-xl border border-slate-700 bg-slate-800 p-5">
                <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-blue-600 text-sm font-black text-white">
                  {step}
                </div>
                <div>
                  <p class="font-bold text-white">{title}</p>
                  <p class="mt-1 whitespace-pre-line text-sm text-slate-400">{body}</p>
                </div>
              </div>
            ))}
          </div>

          <!-- JSON Schema Reference -->
          <div class="rounded-2xl border border-slate-700 bg-slate-950 overflow-hidden">
            <div class="border-b border-slate-700 px-4 py-3 flex items-center gap-2">
              <div class="h-3 w-3 rounded-full bg-red-500"></div>
              <div class="h-3 w-3 rounded-full bg-yellow-500"></div>
              <div class="h-3 w-3 rounded-full bg-green-500"></div>
              <span class="ml-2 text-xs text-slate-500 font-mono">electrical.json — example</span>
            </div>
            <pre class="overflow-x-auto p-4 text-xs leading-relaxed text-emerald-400 font-mono whitespace-pre-wrap"><code set:html={exampleJson} /></pre>
          </div>
        </div>
      </section>

      <!-- 4-Section Schema Breakdown -->
      <section>
        <h2 class="mb-6 text-xl font-bold text-white">The 4-Section Schema</h2>
        <div class="grid gap-4 md:grid-cols-4">
          {[
            {
              num: '①',
              title: 'service_config',
              color: 'border-blue-500/40 bg-blue-900/20',
              items: ['niche + niche_slug', 'category + category_slug', 'icon (emoji)', 'sub_niches[] — label + slug pairs'],
            },
            {
              num: '②',
              title: 'spintax',
              color: 'border-purple-500/40 bg-purple-900/20',
              items: ['synonyms[] array', 'category key (e.g. "service_damage")', 'terms — JSON-stringified string[]', 'Overrides global spintax on same key'],
            },
            {
              num: '③',
              title: 'sub_niche_templates',
              color: 'border-emerald-500/40 bg-emerald-900/20',
              items: ['Keyed by sub-niche slug', 'headline_templates[]', 'faqs[] — q + a pairs', 'lead_magnet — headline, bullets, cta', 'survey — title, steps[]'],
            },
            {
              num: '④',
              title: 'regional_nuance',
              color: 'border-amber-500/40 bg-amber-900/20',
              items: ['Keyed by state code (TX, FL, NC, CO…)', 'focus — e.g. "Slab Leaks & Hard Water"', 'top_brand — regional brand recommendation', 'tech — specific technology', 'logic — spintax-enabled copy block'],
            },
          ].map(({ num, title, color, items }) => (
            <div class={`rounded-2xl border p-5 ${color}`}>
              <p class="text-2xl">{num}</p>
              <p class="mt-2 font-black text-white font-mono text-sm">{title}</p>
              <ul class="mt-4 space-y-2">
                {items.map(item => (
                  <li class="flex gap-2 text-xs text-slate-300">
                    <span class="text-slate-500 flex-shrink-0">—</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>

      <!-- Sample page links for each niche -->
      <section>
        <h2 class="mb-6 text-xl font-bold text-white">Sample Pages (Live)</h2>
        <div class="space-y-3">
          {niches.map((n) => {
            const samples = pseoContent
              .filter(e => e.niche === n.niche)
              .slice(0, 3);
            return (
              <div class="rounded-xl border border-slate-700 bg-slate-800 p-4">
                <p class="mb-3 font-bold capitalize text-white">{n.niche}</p>
                <div class="flex flex-wrap gap-2">
                  {samples.map(s => (
                    <a
                      href={`/${s.slug}`}
                      class="rounded-lg border border-slate-600 bg-slate-700 px-3 py-1.5 text-xs text-slate-300 hover:border-blue-500 hover:text-blue-300 transition font-mono"
                    >
                      /{s.slug.replace('insights/', '')}
                    </a>
                  ))}
                </div>
              </div>
            );
          })}
        </div>
      </section>

    </div>
  </div>
</BaseLayout>
