---
interface Props {
  data: {
    title: string;
    rows: Array<{
      category: string;
      cheap: string;
      premium: string;
    }>;
  };
}

const { data } = Astro.props;
---

<section class="my-16 px-4">
  <div class="mx-auto max-w-4xl">
    <div class="mb-10 text-center">
      <h2 class="text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
        {data.title}
      </h2>
      <p class="mt-4 text-lg italic text-slate-600">
        Not all assemblies are equal for high-event weather—here is a practical contrast.
      </p>
    </div>

    <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-xl">
      <table class="w-full border-collapse text-left">
        <thead>
          <tr class="bg-slate-900 text-white">
            <th class="px-6 py-5 text-sm font-bold uppercase tracking-widest">Feature</th>
            <th class="bg-slate-800/50 px-6 py-5 text-sm font-bold uppercase tracking-widest">
              Standard shingle
            </th>
            <th class="px-6 py-5 text-sm font-bold uppercase tracking-widest text-blue-300">
              Certified armor
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {data.rows.map((row) => (
            <tr class="group transition-colors hover:bg-slate-50">
              <td class="px-6 py-6">
                <span class="block text-sm font-bold text-slate-900">{row.category}</span>
              </td>
              <td class="px-6 py-6 text-sm italic text-slate-500">{row.cheap}</td>
              <td class="bg-blue-50/40 px-6 py-6 transition-colors group-hover:bg-blue-50/60">
                <div class="flex items-center gap-3">
                  <svg class="h-5 w-5 flex-shrink-0 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                    <path
                      fill-rule="evenodd"
                      d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  <span class="text-sm font-bold text-slate-900">{row.premium}</span>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>

      <div class="border-t border-slate-200 bg-slate-50 px-6 py-4">
        <p class="text-center text-[11px] font-medium uppercase leading-tight tracking-tighter text-slate-500">
          Educational summary—not a bid. Verify manufacturer specs and local code with your contractor.
        </p>
      </div>
    </div>
  </div>
</section>
