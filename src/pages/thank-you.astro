---
import BaseLayout from '../layouts/BaseLayout.astro';
import ThankYouContent from '../components/pseo/ThankYouContent.astro';

const city = Astro.url.searchParams.get('city') || 'the Tampa Bay area';
const neighborhood = Astro.url.searchParams.get('neighborhood') || city;
---

<BaseLayout title={`Thank you | ${city}`}>
  <ThankYouContent city={city} neighborhood={neighborhood} />
</BaseLayout>
