---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { pseoContent, type PseoEntry } from '../../utils/pseo';
import RegionalBrandShowcase from '../../components/pseo/RegionalBrandShowcase.astro';
import MaterialShowdown from '../../components/pseo/MaterialShowdown.astro';
import InteractiveGauge from '../../components/pseo/InteractiveGauge.astro';
import ServiceTracker from '../../components/pseo/ServiceTracker.astro';
import EncyclopediaSection from '../../components/pseo/EncyclopediaSection.astro';
import ServiceSurvey from '../../components/pseo/ServiceSurvey.astro';
import ProcessGuide from '../../components/pseo/ProcessGuide.astro';
import SeasonalTips from '../../components/pseo/SeasonalTips.astro';
import ComparisonGuide from '../../components/pseo/ComparisonGuide.astro';
import MarketAnalytics from '../../components/pseo/MarketAnalytics.astro';
import ComplianceChecklist from '../../components/pseo/ComplianceChecklist.astro';
import SiloLinks from '../../components/pseo/SiloLinks.astro';
import LocalMap from '../../components/pseo/LocalMap.astro';

export function getStaticPaths() {
  // slug format: "[loc-slug]/[niche]/[sub-niche]"
  return pseoContent.map((entry) => ({
    params: { slug: entry.slug.replace(/^insights\//, '') },
    props: { entry },
  }));
}

interface Props {
  entry: PseoEntry;
}

interface PageBlock {
  block_type: string;
  data: Record<string, unknown>;
}

interface FaqItem {
  q: string;
  a: string;
}

interface AoeFaqData {
  items: FaqItem[];
}

interface SurveyStep {
  id: string;
  label: string;
  options?: string[];
  placeholder?: string;
}

interface ServiceSurveyBlockData {
  title: string;
  subhead: string;
  steps: SurveyStep[];
  niche: string;
  sub_niche: string;
}

const { entry } = Astro.props;

function renderMarkdown(str: string): string {
  if (!str) return '';
  let res = str;
  res = res.replace(
    /\*\*(.*?)\*\*/g,
    '<strong class="text-slate-900 font-extrabold">$1</strong>'
  );
  res = res.replace(
    /\{([^}]+)\}/g,
    '<strong class="text-blue-600 font-bold">$1</strong>'
  );
  return res;
}

let blocks: PageBlock[] = [];
try {
  blocks = JSON.parse(entry.blocks || '[]') as PageBlock[];
} catch {
  blocks = [];
}
---

<BaseLayout
  title={entry.title}
  description={entry.excerpt ?? `${entry.city} ${entry.niche} guide.`}
  schemaJsonLd={entry.schema}
  niche={entry.niche}
  city={entry.city}
  state={entry.state}
>
  <article class="pseo-service-page" data-niche={entry.niche} data-sub-niche={entry.subNiche}>
    {
      blocks.map((block) => {
        const { block_type, data } = block;

        if (block_type === 'hero') {
          const d = data as {
            badge?: string;
            headline: string;
            subhead?: string;
            cta_label?: string;
            cta_href?: string;
          };
          return (
            <section class="relative overflow-hidden border-b border-slate-200 bg-white px-6 pb-20 pt-28">
              <div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-blue-50/80 via-transparent to-transparent" />
              <div class="relative z-10 mx-auto max-w-4xl text-center">
                {d.badge && (
                  <span
                    class="mb-6 inline-block rounded-full border border-blue-200 bg-blue-50 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-blue-700"
                    set:html={renderMarkdown(d.badge)}
                  />
                )}
                <h1
                  class="mb-6 text-4xl font-extrabold leading-tight text-slate-900 md:text-5xl"
                  set:html={renderMarkdown(d.headline)}
                />
                {d.subhead && (
                  <p class="mb-10 text-xl text-slate-600" set:html={renderMarkdown(d.subhead)} />
                )}
                {d.cta_label && (
                  <a
                    href={d.cta_href || '#service-survey'}
                    class="inline-flex items-center justify-center rounded-xl bg-blue-600 px-8 py-4 text-sm font-bold uppercase tracking-wider text-white shadow-lg shadow-blue-200 transition hover:bg-blue-700"
                    set:html={renderMarkdown(d.cta_label)}
                  />
                )}
              </div>
            </section>
          );
        }

        if (block_type === 'regional_brand_showcase' || block_type === 'regional_snapshot') {
          return <RegionalBrandShowcase data={data as any} />;
        }

        if (block_type === 'brand_showcase') {
          // Generic brand showcase — reuses the same component, data shape is compatible
          return <EncyclopediaSection data={{ brands: (data as any).brands, styles: {}, costs: {}, aoe_intro: '' }} />;
        }

        if (block_type === 'interactive_gauge') {
          return <InteractiveGauge data={data as any} />;
        }

        if (block_type === 'weather_alert') {
          return <ServiceTracker data={data as any} />;
        }

        if (block_type === 'process_guide') {
          return <ProcessGuide data={data as any} />;
        }

        if (block_type === 'seasonal_tips') {
          return <SeasonalTips data={data as any} city={entry.city} />;
        }

        if (block_type === 'comparison_guide') {
          return <ComparisonGuide data={data as any} />;
        }

        if (block_type === 'market_analytics') {
          return <MarketAnalytics data={data as any} city={entry.city} />;
        }

        if (block_type === 'compliance_checklist') {
          return <ComplianceChecklist data={data as any} />;
        }

        if (block_type === 'roof_cross_section') {
          return <RoofCrossSection />;
        }

        if (block_type === 'material_showdown') {
          return <MaterialShowdown data={data as any} />;
        }

        if (block_type === 'encyclopedia') {
          return <EncyclopediaSection data={data as any} niche={entry.niche} />;
        }

        if (block_type === 'local_trust') {
          const d = data as {
            story_headline: string;
            story_body: string;
            secondary_headline: string;
            secondary_body: string;
            permit_headline: string;
            permit_body: string;
            landmark_badge: string;
            landmark_text: string;
          };
          return (
            <section class="my-20 px-4">
              <div class="mx-auto max-w-4xl space-y-12">
                <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm md:p-10">
                  <h2 class="text-2xl font-bold text-slate-900">{d.story_headline}</h2>
                  <p class="mt-4 text-lg leading-relaxed text-slate-600">{d.story_body}</p>
                </div>
                <div class="rounded-3xl border border-slate-200 bg-slate-50 p-8 md:p-10">
                  <h2 class="text-2xl font-bold text-slate-900">{d.secondary_headline}</h2>
                  <p class="mt-4 text-lg leading-relaxed text-slate-600">{d.secondary_body}</p>
                </div>
                <div class="rounded-3xl border border-blue-100 bg-blue-50/40 p-8 md:p-10">
                  <p class="text-xs font-bold uppercase tracking-widest text-blue-700">{d.landmark_badge}</p>
                  <p class="mt-3 text-slate-700">{d.landmark_text}</p>
                </div>
                <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm md:p-10">
                  <h2 class="text-2xl font-bold text-slate-900">{d.permit_headline}</h2>
                  <p class="mt-4 text-lg leading-relaxed text-slate-600">{d.permit_body}</p>
                </div>
              </div>
            </section>
          );
        }

        if (block_type === 'aoe_faq') {
          const d = data as AoeFaqData;
          return (
            <section class="my-20 px-4">
              <div class="mx-auto max-w-3xl">
                <h2 class="text-center text-3xl font-black text-slate-900">Common questions</h2>
                <div class="mt-10 space-y-6">
                  {d.items.map((item) => (
                    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                      <h3 class="text-lg font-bold text-slate-900">{item.q}</h3>
                      <p class="mt-3 leading-relaxed text-slate-600">{item.a}</p>
                    </div>
                  ))}
                </div>
              </div>
            </section>
          );
        }

        if (block_type === 'lead_magnet') {
          const d = data as {
            headline: string;
            subhead: string;
            bullets: string[];
            button: string;
          };
          return (
            <section class="my-20 px-4">
              <div class="mx-auto max-w-3xl rounded-3xl border border-slate-200 bg-white p-10 shadow-xl">
                <h2 class="text-2xl font-bold text-slate-900">{d.headline}</h2>
                <p class="mt-3 text-slate-600">{d.subhead}</p>
                <ul class="mt-8 space-y-3">
                  {d.bullets.map((b) => (
                    <li class="flex gap-3 text-slate-700">
                      <span class="mt-1 text-blue-600">✓</span>
                      <span>{b}</span>
                    </li>
                  ))}
                </ul>
                <a
                  href="#service-survey"
                  class="mt-10 inline-flex rounded-xl bg-blue-600 px-8 py-4 text-sm font-bold uppercase tracking-wider text-white shadow-md hover:bg-blue-700"
                >
                  {d.button}
                </a>
              </div>
            </section>
          );
        }

        if (block_type === 'closing_trust') {
          const d = data as { text: string };
          return (
            <section class="px-4 py-12">
              <div class="mx-auto max-w-3xl rounded-2xl border border-slate-200 bg-slate-900 px-8 py-10 text-center text-white shadow-lg">
                <p class="text-lg leading-relaxed text-slate-100">{d.text}</p>
              </div>
            </section>
          );
        }

        if (block_type === 'roofing_survey' || block_type === 'service_survey') {
          const d = data as ServiceSurveyBlockData;
          return (
            <ServiceSurvey
              data={{ title: d.title, subhead: d.subhead, steps: d.steps }}
              city={entry.city}
              neighborhood={entry.neighborhood}
              niche={d.niche}
            />
          );
        }

        return null;
      })
    }
    
    <LocalMap city={entry.city} state={entry.state} neighborhood={entry.neighborhood} />
    <SiloLinks city={entry.city} currentNiche={entry.niche} />
  </article>
</BaseLayout>
