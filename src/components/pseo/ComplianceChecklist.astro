---
import type { ComplianceChecklistData } from '../../types/pseo';

interface Props {
  data: ComplianceChecklistData;
}

const { data } = Astro.props;
---

<section class="my-24 px-4">
  <div class="mx-auto max-w-4xl rounded-3xl border-2 border-slate-100 bg-slate-50 p-8 md:p-12 shadow-sm">
    <div class="mb-10 text-center">
      <h2 class="text-3xl font-black text-slate-900 tracking-tight">{data.title}</h2>
      <p class="mt-4 text-slate-600 font-medium">{data.warning}</p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2">
      {data.items.map((item, index) => (
        <div class="flex gap-4 p-4 rounded-2xl bg-white border border-slate-100 shadow-sm transition hover:shadow-md">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-green-100 text-green-600 font-bold text-lg">
            ✓
          </div>
          <div>
            <h3 class="font-black text-slate-900 leading-tight mb-1">{item.title}</h3>
            <p class="text-sm text-slate-500 leading-relaxed font-medium">{item.text}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
