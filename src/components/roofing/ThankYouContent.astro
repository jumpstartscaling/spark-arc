---
interface Props {
  city: string;
  neighborhood: string;
}

const { city, neighborhood } = Astro.props;
---

<section class="flex min-h-[70vh] items-center justify-center bg-slate-50 px-4 py-12">
  <div
    class="w-full max-w-2xl overflow-hidden rounded-[3rem] border-2 border-slate-100 bg-white text-center shadow-2xl"
  >
    <div class="relative overflow-hidden bg-slate-900 px-8 py-12">
      <div class="absolute inset-0 opacity-20">
        <svg width="100%" height="100%" viewBox="0 0 100 100" preserveAspectRatio="none">
          <circle cx="50" cy="50" r="40" fill="none" stroke="#3b82f6" stroke-width="0.5">
            <animate attributeName="r" from="40" to="60" dur="3s" repeatCount="indefinite"></animate>
            <animate attributeName="opacity" from="0.5" to="0" dur="3s" repeatCount="indefinite"></animate>
          </circle>
        </svg>
      </div>

      <div class="relative z-10">
        <div
          class="mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-full bg-emerald-500 shadow-lg shadow-emerald-500/30"
        >
          <svg class="h-10 w-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
          </svg>
        </div>
        <h1 class="text-3xl font-black uppercase italic tracking-tighter text-white">
          Diagnosis received
        </h1>
        <p class="mt-2 font-mono text-xs uppercase tracking-[0.3em] text-blue-300" id="request-id-line">
          Reference: —
        </p>
      </div>
    </div>

    <div class="p-10 md:p-16">
      <h2 class="mb-4 text-2xl font-bold text-slate-900">
        We are matching you with a <span class="italic text-blue-600">certified</span> specialist in {
          neighborhood
        }.
      </h2>
      <p class="mb-10 text-lg leading-relaxed text-slate-600">
        Your information was sent to our local {city} response team. To get the fastest inspection window, keep your
        phone nearby.
      </p>

      <div class="grid gap-6 border-t border-slate-100 pt-10 text-left md:grid-cols-3">
        <div class="space-y-2">
          <span class="text-xl font-black italic text-blue-600">01.</span>
          <p class="text-sm font-bold uppercase leading-tight text-slate-800">Reviewing files</p>
          <p class="text-xs text-slate-500">A local specialist is reviewing your notes now.</p>
        </div>
        <div class="space-y-2">
          <span class="text-xl font-black italic text-blue-600">02.</span>
          <p class="text-sm font-bold uppercase leading-tight text-slate-800">The phone call</p>
          <p class="text-xs text-slate-500">
            Expect a call from a local area code within the next 15–30 minutes during business hours.
          </p>
        </div>
        <div class="space-y-2">
          <span class="text-xl font-black italic text-blue-600">03.</span>
          <p class="text-sm font-bold uppercase leading-tight text-slate-800">No-cost inspection</p>
          <p class="text-xs text-slate-500">We will finalize timing for your documented damage review.</p>
        </div>
      </div>

      <div class="mt-12 rounded-2xl border border-slate-100 bg-slate-50 p-6">
        <p class="text-xs font-medium italic leading-relaxed text-slate-400">
          Spark Arc partners are vetted for local quality standards. Verify licensing, insurance, and references with any
          contractor you hire in {city}.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  const el = document.getElementById('request-id-line');
  if (el) {
    const id = Math.random().toString(36).toUpperCase().substring(2, 10);
    el.textContent = `Reference: ${id}`;
  }
</script>
