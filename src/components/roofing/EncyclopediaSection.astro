---
interface BrandEntry {
  tier: string;
  flagship: string;
  value_prop: string;
  price_point: string;
}

interface StyleEntry {
  human_name: string;
  benefit: string;
  aoe_hint: string;
}

interface CostEntry {
  per_sqft: string;
  notes: string;
}

interface Props {
  data: {
    brands: Record<string, BrandEntry>;
    styles: Record<string, StyleEntry>;
    costs: Record<string, CostEntry>;
    aoe_intro: string;
  };
}

const { data } = Astro.props;

const brandKeys = Object.keys(data.brands);
const styleKeys = Object.keys(data.styles);
const costKeys = Object.keys(data.costs);
---

<section class="my-20 px-4">
  <div class="mx-auto max-w-4xl">
    <p class="text-lg leading-relaxed text-slate-600">{data.aoe_intro}</p>

    <h2 class="mt-16 text-2xl font-black uppercase tracking-tighter text-slate-900">Major brands</h2>
    <div class="mt-6 grid gap-4 md:grid-cols-2">
      {
        brandKeys.map((key) => {
          const b = data.brands[key]!;
          return (
            <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
              <p class="text-xs font-bold uppercase tracking-widest text-blue-600">{key.replace(/_/g, ' ')}</p>
              <p class="mt-2 text-sm text-slate-500">{b.tier} · flagship: {b.flagship}</p>
              <p class="mt-3 text-slate-800">{b.value_prop}</p>
              <p class="mt-2 text-sm font-semibold text-slate-600">Typical tier: {b.price_point}</p>
            </div>
          );
        })
      }
    </div>

    <h2 class="mt-16 text-2xl font-black uppercase tracking-tighter text-slate-900">Roof shapes</h2>
    <ul class="mt-6 space-y-4">
      {
        styleKeys.map((key) => {
          const s = data.styles[key]!;
          return (
            <li class="rounded-2xl border border-slate-100 bg-slate-50/80 px-6 py-4">
              <p class="font-bold text-slate-900">
                {key}: {s.human_name}
              </p>
              <p class="mt-1 text-slate-600">{s.benefit}</p>
              <p class="mt-2 text-sm text-slate-500">{s.aoe_hint}</p>
            </li>
          );
        })
      }
    </ul>

    <h2 class="mt-16 text-2xl font-black uppercase tracking-tighter text-slate-900">2026 cost benchmarks</h2>
    <div class="mt-6 overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
      <table class="w-full text-left text-sm">
        <thead class="bg-slate-900 text-white">
          <tr>
            <th class="px-4 py-3 font-bold uppercase tracking-wider">System</th>
            <th class="px-4 py-3 font-bold uppercase tracking-wider">$/sq.ft.</th>
            <th class="px-4 py-3 font-bold uppercase tracking-wider">Notes</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {
            costKeys.map((key) => {
              const c = data.costs[key]!;
              return (
                <tr class="hover:bg-slate-50">
                  <td class="px-4 py-3 font-semibold text-slate-800">{key.replace(/_/g, ' ')}</td>
                  <td class="px-4 py-3 text-blue-700">{c.per_sqft}</td>
                  <td class="px-4 py-3 text-slate-600">{c.notes}</td>
                </tr>
              );
            })
          }
        </tbody>
      </table>
    </div>
  </div>
</section>
