---
interface Props {
  data: {
    headline: string;
    body: string;
  };
}

const { data } = Astro.props;
---

<section class="relative overflow-hidden bg-slate-100 px-4 py-20">
  <div class="pointer-events-none absolute inset-0 opacity-30">
    <svg width="100%" height="100%" viewBox="0 0 400 400" preserveAspectRatio="xMidYMid slice">
      <circle cx="200" cy="200" r="1" fill="#2563eb">
        <animate attributeName="r" from="1" to="300" dur="4s" repeatCount="indefinite"></animate>
        <animate attributeName="opacity" from="0.5" to="0" dur="4s" repeatCount="indefinite"></animate>
      </circle>
      <circle cx="200" cy="200" r="1" fill="#2563eb">
        <animate attributeName="r" from="1" to="300" dur="4s" begin="2s" repeatCount="indefinite"></animate>
        <animate attributeName="opacity" from="0.5" to="0" dur="4s" begin="2s" repeatCount="indefinite"></animate>
      </circle>
      <line x1="0" y1="200" x2="400" y2="200" stroke="#cbd5e1" stroke-width="1"></line>
      <line x1="200" y1="0" x2="200" y2="400" stroke="#cbd5e1" stroke-width="1"></line>
    </svg>
  </div>

  <div class="relative z-10 mx-auto flex max-w-4xl flex-col items-center gap-12 md:flex-row">
    <div class="md:w-1/2">
      <h2
        class="mb-6 text-4xl font-black uppercase italic leading-none tracking-tighter text-slate-900"
      >
        {data.headline}
      </h2>
      <p class="text-lg leading-relaxed text-slate-600">
        {data.body}
      </p>
    </div>

    <div
      class="md:w-1/2 rounded-2xl border border-slate-200 bg-white/90 p-6 shadow-xl backdrop-blur-md"
    >
      <div class="space-y-4">
        <div
          class="flex items-center justify-between border-b border-slate-200 pb-2 font-mono text-xs uppercase tracking-widest text-slate-500"
        >
          <span>Neighborhood context</span>
          <span class="text-blue-600">Document now</span>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="rounded-lg bg-slate-50 p-3">
            <span class="block text-[10px] uppercase text-slate-500">Hail risk framing</span>
            <span class="text-xl font-bold tracking-tighter text-slate-900">Check metal</span>
          </div>
          <div class="rounded-lg bg-slate-50 p-3">
            <span class="block text-[10px] uppercase text-slate-500">Wind framing</span>
            <span class="text-xl font-bold tracking-tighter text-red-600">Edge zones</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
