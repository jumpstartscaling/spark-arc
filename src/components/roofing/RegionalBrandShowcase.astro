---
interface Props {
  data: {
    title: string;
    brand_name: string;
    technology: string;
    description: string;
  };
}

const { data } = Astro.props;
---

<section class="my-12 px-4">
  <div class="mx-auto max-w-4xl overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
    <div class="flex items-center justify-between border-b border-slate-100 bg-slate-900 px-6 py-3">
      <span class="text-xs font-bold uppercase tracking-widest text-slate-400">
        Regional technology note
      </span>
      <div class="flex items-center gap-2">
        <div class="h-2 w-2 animate-pulse rounded-full bg-emerald-500"></div>
        <span class="font-mono text-[10px] uppercase text-emerald-400">Code-aware installs</span>
      </div>
    </div>

    <div class="flex flex-col items-center gap-8 p-8 md:flex-row md:p-10">
      <div
        class="flex w-full flex-col items-center justify-center rounded-xl border border-slate-100 bg-slate-50 p-6 text-center shadow-inner md:w-1/3"
      >
        <p class="mb-1 text-xs font-bold uppercase text-slate-400">Featured brand class</p>
        <h3 class="text-2xl font-black uppercase italic leading-none tracking-tight text-slate-800">
          {data.brand_name}
        </h3>
        <div
          class="mt-4 rounded bg-blue-600 px-3 py-1 text-[10px] font-bold uppercase tracking-tighter text-white"
        >
          {data.technology}
        </div>
      </div>

      <div class="w-full md:w-2/3">
        <h2 class="mb-4 text-2xl font-bold leading-tight text-slate-900">
          {data.title}
        </h2>
        <p class="text-lg leading-relaxed text-slate-600">
          {data.description}
        </p>

        <div class="mt-6 grid grid-cols-2 gap-4 border-t border-slate-200 pt-6">
          <div>
            <p class="text-[10px] font-bold uppercase text-slate-400">Fastening discipline</p>
            <p class="text-sm font-semibold italic text-slate-700">Six-nail zones where spec requires</p>
          </div>
          <div>
            <p class="text-[10px] font-bold uppercase text-slate-400">Climate lens</p>
            <p class="text-sm font-semibold italic text-slate-700">Wind + water managed as a system</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
